# .gitignore para projetos Python/FastAPI

# Byte-compiled / cache / logs
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.log

# Virtual environments
.env/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# VSCode
.vscode/

# Pytest
.cache/
.pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover

# Jupyter
.ipynb_checkpoints

# Alembic
alembic/versions/*.pyc

# Database
*.sqlite3
*.db

# Environment/config
.env
.env.*

# Docker
*.pid
*.pid.lock

# OS
.DS_Store
Thumbs.db

# Build
build/
dist/
*.egg-info/
.eggs/

# Frontend/React/Node.js
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/coverage/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/.stylelintcache
frontend/*.tsbuildinfo

# Cypress (E2E testing)
frontend/cypress/screenshots/
frontend/cypress/videos/
frontend/cypress/downloads/

# Storybook
frontend/storybook-static/