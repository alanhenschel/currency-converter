# Sample .env.example file for the currency converter project

# This file contains example environment variables for the currency converter application.

# Database configuration
DATABASE_URL=postgresql://username:password@localhost:5432/currency_converter

# API configuration
CURRENCY_API_URL=https://app.currencyapi.com/
CURRENCY_API_KEY=your_api_key_here

# Logging configuration
LOG_LEVEL=info

# Other configurations
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here

# Add any additional environment variables as needed for your application.